# Copy this file to .env and fill in real values before running docker compose up.
# .env is gitignored — never commit it.

# HS256 signing key for JWTs — any long random string works
JWT_SECRET=change-me-in-production-needs-at-least-32-chars!!

# Free API key from https://twelvedata.com (register, then Dashboard → API Keys)
TWELVE_DATA_API_KEY=YOUR_KEY_HERE
